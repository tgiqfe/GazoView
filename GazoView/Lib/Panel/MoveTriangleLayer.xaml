<UserControl x:Class="GazoView.Lib.Panel.MoveTriangleLayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GazoView.Lib.Panel"
             mc:Ignorable="d">
    <Grid>
        <!-- Left navigation area -->
        <Border x:Name="LeftTriangleArea"
                HorizontalAlignment="Left"
                Visibility="Collapsed"
                Background="Transparent"
                Width="60"
                MouseLeftButtonDown="LeftTriangle_Click"
                Cursor="Hand">
            <Path HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Fill="#80707070"
                  Margin="20,0,0,0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="30,0">
                            <LineSegment Point="0,40" />
                            <LineSegment Point="30,80" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Border>

        <!-- Right navigation area -->
        <Border x:Name="RightTriangleArea"
                HorizontalAlignment="Right"
                Visibility="Collapsed"
                Background="Transparent"
                Width="60"
                MouseLeftButtonDown="RightTriangle_Click"
                Cursor="Hand">
            <Path HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Fill="#80707070"
                  Margin="0,0,20,0">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0">
                            <LineSegment Point="30,40" />
                            <LineSegment Point="0,80" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Border>
    </Grid>
</UserControl>
