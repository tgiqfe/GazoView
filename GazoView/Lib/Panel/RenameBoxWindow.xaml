<Window x:Class="GazoView.Lib.Panel.RenameBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GazoView.Lib.Panel"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Name="RenameBox"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="80" Width="590">
    
    <Window.Resources>
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="0,18,18,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="2"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NoHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <materialDesign:PackIcon x:Name="NormalIcon"
                                                         Kind="ArrowRightBoldBoxOutline"
                                                         Width="30"
                                                         Height="Auto"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                <materialDesign:PackIcon x:Name="PressedIcon"
                                                         Kind="ArrowRightBoldBox"
                                                         Width="30"
                                                         Height="Auto"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NormalIcon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PressedIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Name="RenameWindowBase"
                CornerRadius="0,0,20,20" Background="#DFDFDF"
                MouseLeftButtonUp="RenameWindowBase_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FormTextbox"
                                         Width="40"
                                         Height="Auto"
                                         Margin="10,5,0,5"        
                                         Padding="5"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                <Border Width="38" 
                        Height="36" 
                        CornerRadius="18,0,0,18"
                        BorderThickness="1"
                        BorderBrush="#bdbdbd"
                        Background="White"
                        Margin="5,5,0,5">
                    <!-- CheckCircle, CloseCircle, PencilCircle -->
                    <materialDesign:PackIcon Kind="PencilCircle"
                                         Width="25"
                                         Height="Auto"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Foreground="Gray"/>
                </Border>
                <TextBox Name="TextBoxForFileName"
                         Width="300"
                         Height="36"
                         Margin="-1,5,5,5"
                         Padding="5"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         FontFamily="Noto Sans JP"
                         FontSize="16"
                         Style="{StaticResource RoundedTextBoxStyle}"/>
                <TextBlock Text=".png"
                           Margin="5,1,5,5" 
                           MaxWidth="100"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Stretch"
                           FontFamily="Noto Sans JP"
                           FontSize="18"/>
                <Button Margin="15,5"
                        Width="30"
                        Height="30"
                        BorderThickness="0"
                        Style="{StaticResource NoHoverButtonStyle}">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
